# web_security_platform v2 example environment variables
SECRET_KEY=replace_with_secure_value
DATABASE_URL=sqlite+aiosqlite:///./webguard.db
DEBUG=False
RATE_LIMIT_PER_MINUTE=100
ADMIN_PASSWORD=
PORT=8000
# WebGuard Pro — Environment Configuration
# Copy this to .env and fill in your values

APP_NAME=WebGuard Pro
VERSION=2.0.0
DEBUG=false

# SECURITY — Change this in production!
SECRET_KEY=change-this-to-a-long-random-secret-key-in-production

# Database
DATABASE_URL=sqlite+aiosqlite:///./webguard.db
# For PostgreSQL:
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/webguard

# CORS - comma separated origins
ALLOWED_ORIGINS=["http://localhost:8000","http://127.0.0.1:8000"]

# Rate limiting
RATE_LIMIT_PER_MINUTE=100

# Scanner
SCANNER_TIMEOUT=30
MAX_CONCURRENT_SCANS=5
